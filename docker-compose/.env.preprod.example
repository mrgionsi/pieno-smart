# PienoSmart Pre-Production Environment Variables
# Copy this file to .env.preprod and customize for your environment

# Database Configuration
DB_PASSWORD=your_secure_db_password_here

# CORS Settings (comma-separated URLs)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://pienosmart-preprod.example.com

# Frontend API Configuration
FRONTEND_API_BASE_URL=http://backend:8000/api

# Development User (for testing - remove in production)
DEV_USER_EMAIL=demo@pienosmart.local
DEV_USER_DISPLAY_NAME=Demo User
DEV_USER_SUBJECT=dev-local-user

# External API Settings
MIMIT_HTTP_TIMEOUT_SECONDS=30.0
MIMIT_HTTP_MAX_RETRIES=3